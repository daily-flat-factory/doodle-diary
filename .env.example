# ============================================================
# Doodle-Diary 환경변수 설정
# 이 파일을 복사해서 .env 로 사용하세요
# ============================================================

# Flask
# TODO : 개발 환경에서는 'development', 배포 시에는 'production'으로 변경
FLASK_ENV=development   
# 실제 배포 시에는 반드시 안전한 값으로 변경하세요
SECRET_KEY=your-super-secret-key-change-this

# OpenAI API (텍스트 → 이미지 프롬프트 변환)
OPENAI_API_KEY=sk-ant-...

# HuggingFace API (이미지 생성)
HF_API_KEY=hf_...
HF_MODEL_ID=black-forest-labs/FLUX.1-schnell   # 어린이 그림체 특화 모델

# 일일 생성 제한
DAILY_LIMIT=3

# DB
DATABASE_PATH=./doodle_diary.db

# 이미지 저장 경로
IMAGE_SAVE_PATH=./static/images/generated
